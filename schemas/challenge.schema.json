{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DORAEMON Challenge",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "summary",
    "category",
    "technical_area",
    "detector_type",
    "datasets",
    "metrics"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "order": {
      "type": "number"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["planned", "active"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "technical_area": {
      "type": "string",
      "minLength": 1
    },
    "physics_area": {
      "type": "string"
    },
    "detector_type": {
      "type": "string",
      "minLength": 1
    },
    "detector_types": false,
    "technical_method": {
      "type": "string",
      "minLength": 1
    },
    "datasets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "metrics": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "hero_image": {
      "type": "object",
      "required": ["src", "alt"],
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "position": {
          "type": "string"
        },
        "caption": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "image": {
      "type": "string"
    },
    "links": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "null"]
      }
    }
  },
  "additionalProperties": true
}
