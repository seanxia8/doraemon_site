{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "challengeRegistry": {
      "type": "object",
      "required": ["version", "challenges"],
      "properties": {
        "version": {
          "type": "integer"
        },
        "challenges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "status", "path"],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "category": {
                "type": "string"
              },
              "technical_area": {
                "type": "string"
              },
              "dataset_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "metric_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "path": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    },
    "datasetRegistry": {
      "type": "object",
      "required": ["version", "datasets"],
      "properties": {
        "version": {
          "type": "integer"
        },
        "datasets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "status", "path"],
            "properties": {
              "id": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "modality": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": false
    }
  }
}
