{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DORAEMON Dataset",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "summary",
    "modality",
    "version",
    "access"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["planned", "draft", "released", "deprecated"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "modality": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "access": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string"
        },
        "url": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "schema_doc": {
      "type": "string"
    },
    "example_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
